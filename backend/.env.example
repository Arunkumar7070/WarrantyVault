# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=warrantyvault

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Blockchain (Base Sepolia)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CONTRACT_ADDRESS=
# Private key of the wallet the backend uses to sign registerWarranty/revokeWarranty
# transactions. This wallet must be added as a registrar on the deployed contract.
# Never commit the real value.
BACKEND_OPERATOR_PRIVATE_KEY=

# Pinata (IPFS invoice storage) - https://app.pinata.cloud
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Public frontend URL, used to build QR/verification links
FRONTEND_URL=http://localhost:5173
